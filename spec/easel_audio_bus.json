{
  "version": "1.0",
  "namespace": "audio",
  "notes": "Canonical EaselAudio bus. 'existing' uniforms keep their current per-product semantics (now AGC'd); products may carry extra legacy uniforms beyond this list — nothing is removed. All floats 0-1 unless range says otherwise. Times/coefficients are dt-derived (seconds), never per-frame alphas.",
  "uniforms": [
    { "name": "audioLevel",      "type": "float", "range": [0, 1], "group": "core", "existing": true,  "desc": "AGC'd full-mix level (smoothed follower, visual-binding 10/500ms feel)" },
    { "name": "audioBass",       "type": "float", "range": [0, 1], "group": "core", "existing": true,  "desc": "AGC'd bass band level" },
    { "name": "audioMid",        "type": "float", "range": [0, 1], "group": "core", "existing": true,  "desc": "AGC'd mid band level" },
    { "name": "audioHigh",       "type": "float", "range": [0, 1], "group": "core", "existing": true,  "desc": "AGC'd high band level" },
    { "name": "audioSub",        "type": "float", "range": [0, 1], "group": "core", "existing": true,  "desc": "AGC'd sub band (<60Hz-ish) level" },
    { "name": "audioTreble",     "type": "float", "range": [0, 1], "group": "core", "existing": true,  "desc": "AGC'd treble/air band level" },
    { "name": "audioEnergy",     "type": "float", "range": [0, 1], "group": "core", "existing": true,  "desc": "Broadband energy, slower macro feel" },
    { "name": "audioBrightness", "type": "float", "range": [0, 1], "group": "core", "existing": true,  "desc": "Spectral centroid normalized" },
    { "name": "audioPunch",      "type": "float", "range": [0, 1], "group": "events", "existing": true, "desc": "Transient punch envelope (fast attack, decaying)" },
    { "name": "audioBeatPulse",  "type": "float", "range": [0, 1], "group": "events", "existing": true, "desc": "Beat-triggered decaying envelope (~300-600ms)" },
    { "name": "audioOnset",      "type": "float", "range": [0, 1], "group": "events", "existing": true, "desc": "Onset strength envelope" },
    { "name": "audioBeat",       "type": "float", "range": [0, 1], "group": "events", "existing": true, "desc": "Raw beat gate (avoid direct use; prefer audioBeatPulse)" },
    { "name": "audioFFT",        "type": "sampler2D", "group": "texture", "existing": true, "desc": "Spectrum texture; target layout RGBA: R=raw, G=juiced log default, B=smooth, A=waveform; log-frequency x" },

    { "name": "audioBassHit",      "type": "float", "range": [0, 1], "group": "temperament.hit", "desc": "Bass dual-follower onset, AD 10ms/350ms pow 1.0/1.6, self-normalizing" },
    { "name": "audioMidHit",       "type": "float", "range": [0, 1], "group": "temperament.hit", "desc": "Mid dual-follower onset" },
    { "name": "audioHighHit",      "type": "float", "range": [0, 1], "group": "temperament.hit", "desc": "High dual-follower onset" },
    { "name": "audioBassPresence", "type": "float", "range": [0, 1], "group": "temperament.presence", "desc": "Bass slow macro envelope (attack 1.5s / release 4s)" },
    { "name": "audioMidPresence",  "type": "float", "range": [0, 1], "group": "temperament.presence", "desc": "Mid slow macro envelope" },
    { "name": "audioHighPresence", "type": "float", "range": [0, 1], "group": "temperament.presence", "desc": "High slow macro envelope" },
    { "name": "audioPresence",     "type": "float", "range": [0, 1], "group": "temperament.presence", "desc": "Mix slow macro envelope" },
    { "name": "audioBassTime",     "type": "float", "range": [0, null], "group": "temperament.time", "desc": "Monotonic clock += dt*audioBass (unclamped; use as time source)" },
    { "name": "audioMidTime",      "type": "float", "range": [0, null], "group": "temperament.time", "desc": "Monotonic clock += dt*audioMid" },
    { "name": "audioHighTime",     "type": "float", "range": [0, null], "group": "temperament.time", "desc": "Monotonic clock += dt*audioHigh" },
    { "name": "audioTime",         "type": "float", "range": [0, null], "group": "temperament.time", "desc": "Monotonic clock += dt*audioLevel" },

    { "name": "audioBPM",           "type": "float", "range": [0, 300], "group": "rhythm", "desc": "Detected/locked tempo (absolute BPM; 0 = unknown)" },
    { "name": "audioBPMConfidence", "type": "float", "range": [0, 1], "group": "rhythm", "desc": "Tempo confidence; <0.4 means fall back to level-driven" },
    { "name": "audioBeatPhase",     "type": "float", "range": [0, 1], "group": "rhythm", "desc": "Phase ramp within current beat" },
    { "name": "audioBarPhase",      "type": "float", "range": [0, 1], "group": "rhythm", "desc": "Phase ramp within current 4-beat bar" },
    { "name": "audioPhase2",        "type": "float", "range": [0, 1], "group": "rhythm", "desc": "Phase ramp over 2 beats" },
    { "name": "audioPhase4",        "type": "float", "range": [0, 1], "group": "rhythm", "desc": "Phase ramp over 4 beats" },
    { "name": "audioPhase8",        "type": "float", "range": [0, 1], "group": "rhythm", "desc": "Phase ramp over 8 beats" },
    { "name": "audioPhase16",       "type": "float", "range": [0, 1], "group": "rhythm", "desc": "Phase ramp over 16 beats" },
    { "name": "audioOnBeat",        "type": "float", "range": [0, 1], "group": "rhythm", "desc": "Logistic-eased one-shot on each beat (~120ms)" },
    { "name": "audioToggleOnBeat",  "type": "float", "range": [0, 1], "group": "rhythm", "desc": "Eased 0/1 flip each beat" },

    { "name": "stemBass",   "type": "float", "range": [0, 1], "group": "stems", "desc": "Sub+low LR band level (<120Hz): bassline+kick body" },
    { "name": "stemDrums",  "type": "float", "range": [0, 1], "group": "stems", "desc": "HPSS percussive level (all-band transients)" },
    { "name": "stemMelody", "type": "float", "range": [0, 1], "group": "stems", "desc": "Harmonic minus sub (tonal body 120Hz-2k)" },
    { "name": "stemAir",    "type": "float", "range": [0, 1], "group": "stems", "desc": ">2k harmonic wash (pads/cymbals)" },
    { "name": "stemVocal",  "type": "float", "range": [0, 1], "group": "stems", "desc": "2-6kHz harmonic x flux gate: vocal presence approximation" },
    { "name": "stemBassHit",        "type": "float", "range": [0, 1], "group": "stems.hit", "desc": "Onset of stemBass" },
    { "name": "stemDrumsHit",       "type": "float", "range": [0, 1], "group": "stems.hit", "desc": "Onset of stemDrums (lower threshold — bleed-free)" },
    { "name": "stemMelodyHit",      "type": "float", "range": [0, 1], "group": "stems.hit", "desc": "Onset of stemMelody" },
    { "name": "stemAirHit",         "type": "float", "range": [0, 1], "group": "stems.hit", "desc": "Onset of stemAir" },
    { "name": "stemVocalHit",       "type": "float", "range": [0, 1], "group": "stems.hit", "desc": "Onset of stemVocal" },
    { "name": "stemBassPresence",   "type": "float", "range": [0, 1], "group": "stems.presence", "desc": "Presence of stemBass" },
    { "name": "stemDrumsPresence",  "type": "float", "range": [0, 1], "group": "stems.presence", "desc": "Presence of stemDrums" },
    { "name": "stemMelodyPresence", "type": "float", "range": [0, 1], "group": "stems.presence", "desc": "Presence of stemMelody" },
    { "name": "stemAirPresence",    "type": "float", "range": [0, 1], "group": "stems.presence", "desc": "Presence of stemAir" },
    { "name": "stemVocalPresence",  "type": "float", "range": [0, 1], "group": "stems.presence", "desc": "Presence of stemVocal" }
  ],
  "conditioning": {
    "chain": ["gate", "attack", "hold", "release", "hardChangeThreshold", "character", "remap", "microSlew"],
    "defaults": { "gateDb": -60, "gateHysteresisDb": 3, "attackSec": 0.01, "attackPow": 1.0, "holdSec": 0.0, "releaseSec": 0.5, "releasePow": 1.0, "hardChangeThreshold": 0.35, "character": -0.5, "microSlewSec": 0.003 },
    "rolePresets": {
      "general":       { "attackSec": 0.01, "releaseSec": 0.1 },
      "visualBinding": { "attackSec": 0.01, "releaseSec": 0.5 },
      "meter":         { "attackSec": 0.3,  "releaseSec": 0.3 },
      "stem":          { "attackSec": 0.01, "releaseSec": 0.75 }
    }
  },
  "agc": { "noiseFloorDb": -60, "rangeGrowSec": 0.1, "rangeShrinkSec": 60, "defaultOn": true },
  "globalControls": { "intensity": 0.22, "character": -0.5, "manualGain": null }
}
